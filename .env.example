# Ejemplo de variables de entorno para producción en Vercel
# Copia este archivo a .env para desarrollo local
# En Vercel, debes agregar VITE_API_URL en la sección de "Environment Variables" de tu proyecto,
# apuntando a la URL pública de tu backend (Ej: https://mi-backend-defensoria.onrender.com)

VITE_API_URL=http://127.0.0.1:8000
